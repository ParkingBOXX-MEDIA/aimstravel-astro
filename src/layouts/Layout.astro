---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "AIMS Travel — international group tour inspiration for cultural journeys to Africa, Asia, Europe, the Americas, and the Middle East." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | AIMS Travel</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --burgundy: #7b1c2e;
        --burgundy-dark: #4a0f1a;
        --gold: #c9a227;
        --gold-light: #e8c84a;
        --cream: #faf7f0;
        --sand: #f0ebe0;
        --text: #2c2416;
        --muted: #7a6a55;
        --border: #d8cdb8;
        --white: #ffffff;
      }

      body {
        font-family: 'Source Sans 3', Arial, Helvetica, sans-serif;
        color: var(--text);
        background: var(--white);
        line-height: 1.75;
        font-size: 1.05rem;
      }

      /* ── HEADER ── */
      header {
        background: var(--burgundy-dark);
        border-bottom: 3px solid var(--gold);
        padding: 0 1.5rem;
      }
      .header-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.2rem 0;
      }
      .site-brand {
        text-decoration: none;
      }
      .brand-text .name {
        display: block;
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        color: var(--gold-light);
        line-height: 1.2;
      }
      .brand-text .tagline {
        display: block;
        font-family: 'Source Sans 3', Arial, sans-serif;
        font-size: 0.78rem;
        color: #c8b898;
        font-style: italic;
        letter-spacing: 0.06em;
        margin-top: 0.15rem;
      }

      /* ── NAV ── */
      nav {
        background: var(--burgundy);
        border-bottom: 2px solid var(--gold);
      }
      .nav-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0;
      }
      nav a {
        color: #e8d8c8;
        text-decoration: none;
        font-family: 'Source Sans 3', Arial, sans-serif;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        padding: 0.7rem 1rem;
        display: inline-block;
        transition: background 0.15s, color 0.15s;
        border-bottom: 3px solid transparent;
      }
      nav a:hover, nav a.active {
        color: var(--gold-light);
        border-bottom-color: var(--gold);
        background: rgba(255,255,255,0.07);
      }

      /* ── SITE NOTICE BAR ── */
      .site-notice {
        background: var(--sand);
        border-bottom: 1px solid var(--border);
        font-family: 'Source Sans 3', Arial, sans-serif;
        font-size: 0.78rem;
        color: var(--muted);
        text-align: center;
        padding: 0.35rem 1.5rem;
      }

      /* ── HERO BAND ── */
      .hero-band {
        background: linear-gradient(135deg, var(--burgundy-dark) 0%, #7b1c2e 100%);
        color: var(--white);
        padding: 3.5rem 1.5rem;
        text-align: center;
        border-bottom: 3px solid var(--gold);
      }
      .hero-band h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 2.4rem;
        font-weight: 700;
        color: var(--gold-light);
        margin-bottom: 0.5rem;
        letter-spacing: 0.01em;
      }
      .hero-band p {
        font-family: 'Source Sans 3', Arial, sans-serif;
        font-style: italic;
        color: #d8c8b0;
        font-size: 1.1rem;
      }

      /* ── HERO IMAGE PLACEHOLDER ── */
      .dest-hero-img {
        width: 100%;
        max-width: 860px;
        margin: 0 auto 2rem;
        display: block;
        border-radius: 4px;
        object-fit: cover;
      }
      .img-placeholder {
        width: 100%;
        max-width: 860px;
        margin: 0 auto 2rem;
        background: var(--sand);
        border: 2px dashed var(--border);
        border-radius: 4px;
        padding: 2.5rem 1.5rem;
        text-align: center;
        font-family: 'Source Sans 3', Arial, sans-serif;
        font-size: 0.85rem;
        color: var(--muted);
      }
      .img-placeholder strong { display: block; color: var(--burgundy); margin-bottom: 0.25rem; font-size: 0.95rem; }

      /* ── MAIN CONTENT ── */
      main {
        max-width: 860px;
        margin: 2.5rem auto;
        padding: 0 2.5rem 3rem 3rem;
      }

      h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--burgundy-dark);
        margin-bottom: 1rem;
        border-bottom: 2px solid var(--gold);
        padding-bottom: 0.5rem;
      }
      h2 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.5rem;
        color: var(--burgundy-dark);
        margin: 2rem 0 0.75rem;
      }
      h3 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.2rem;
        color: var(--burgundy);
        margin: 1.5rem 0 0.5rem;
      }
      p { margin-bottom: 1rem; }
      ul, ol { margin: 0 0 1rem 1.5rem; }
      li { margin-bottom: 0.35rem; }
      a { color: #7b1c2e; text-decoration: underline; }
      a:hover { color: var(--burgundy-dark); }

      .card {
        background: var(--cream);
        border: 1px solid var(--border);
        border-left: 4px solid var(--gold);
        border-radius: 4px;
        padding: 1.25rem 1.5rem;
        margin: 1.5rem 0;
      }
      .card h3 { margin-top: 0; }

      table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.95rem; }
      th { background: var(--burgundy-dark); color: var(--white); padding: 0.6rem 0.8rem; text-align: left; font-family: 'Source Sans 3', Arial, sans-serif; }
      td { padding: 0.55rem 0.8rem; border-bottom: 1px solid var(--border); }
      tr:nth-child(even) td { background: var(--cream); }

      .dest-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1.25rem;
        margin: 1.5rem 0;
      }
      .dest-card {
        border: 1px solid var(--border);
        border-top: 4px solid var(--burgundy);
        border-radius: 4px;
        padding: 1.1rem 1.25rem;
        background: var(--cream);
        text-decoration: none;
        color: var(--text);
        display: block;
        transition: border-top-color 0.15s, box-shadow 0.15s;
      }
      .dest-card:hover { border-top-color: var(--gold); box-shadow: 0 3px 12px rgba(0,0,0,0.1); text-decoration: none; }
      .dest-card h3 {
        font-family: 'Playfair Display', Georgia, serif;
        margin: 0 0 0.4rem;
        color: var(--burgundy-dark);
        font-size: 1.05rem;
      }
      .dest-card p { margin: 0; font-size: 0.88rem; color: var(--muted); font-family: 'Source Sans 3', Arial, sans-serif; }

      /* ── FOOTER ── */
      footer {
        background: var(--burgundy-dark);
        border-top: 3px solid var(--gold);
        color: #c8a888;
        font-family: 'Source Sans 3', Arial, Helvetica, sans-serif;
        font-size: 0.82rem;
        padding: 2rem 1.5rem;
      }
      .footer-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
      }
      footer h4 {
        font-family: 'Source Sans 3', Arial, sans-serif;
        color: var(--gold-light);
        margin-bottom: 0.6rem;
        font-size: 0.85rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      footer a { color: #d8b888; text-decoration: none; }
      footer a:hover { color: var(--gold-light); text-decoration: underline; }
      footer ul { list-style: none; padding: 0; }
      footer li { margin-bottom: 0.3rem; }
      .footer-note {
        max-width: 1100px;
        margin: 1.5rem auto 0;
        padding-top: 1.2rem;
        border-top: 1px solid #3a1a0a;
        color: #8a6848;
        font-style: italic;
        line-height: 1.5;
      }
      .footer-bottom {
        max-width: 1100px;
        margin: 0.75rem auto 0;
        color: #5a3828;
        font-size: 0.75rem;
      }

      @media (max-width: 640px) {
        .header-inner { flex-direction: column; text-align: center; }
        .footer-inner { grid-template-columns: 1fr; }
        .hero-band h1 { font-size: 1.6rem; }
        nav a { font-size: 0.75rem; padding: 0.6rem 0.65rem; }
        main { padding: 0 1.25rem 2rem 1.25rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href="/" class="site-brand">
          <div class="brand-text">
            <span class="name">AIMS Travel</span>
            <span class="tagline">Aiming to Make Your Travel Amazing</span>
          </div>
        </a>
      </div>
    </header>

    <nav>
      <div class="nav-inner">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/destinations">Destinations</a>
        <a href="/destinations/africa">Africa</a>
        <a href="/destinations/asia">Asia</a>
        <a href="/destinations/europe">Europe</a>
        <a href="/destinations/americas">Americas</a>
        <a href="/destinations/middle-east">Middle East</a>
        <a href="/news">Travel Ideas</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>

    <div class="site-notice">
      Independent travel resource · Not affiliated with any current tour operator
    </div>

    <slot />

    <footer>
      <div class="footer-inner">
        <div>
          <h4>Destinations</h4>
          <ul>
            <li><a href="/destinations/africa">Africa</a></li>
            <li><a href="/destinations/asia">Asia &amp; the Orient</a></li>
            <li><a href="/destinations/europe">Europe</a></li>
            <li><a href="/destinations/americas">The Americas</a></li>
            <li><a href="/destinations/middle-east">Middle East</a></li>
          </ul>
        </div>
        <div>
          <h4>Explore</h4>
          <ul>
            <li><a href="/about">About AIMS Travel</a></li>
            <li><a href="/news">Travel Ideas</a></li>
            <li><a href="/destinations">All Destinations</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-note">
        AIMS Travel is an independent travel resource celebrating international group travel and cultural exploration. Not affiliated with any tour operator or booking service.
      </div>
      <div class="footer-bottom">
        &copy; {new Date().getFullYear()} aimstravel.com — International travel inspiration
      </div>
    </footer>
  </body>
</html>
